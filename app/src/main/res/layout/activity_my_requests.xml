<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_orange"
    android:gravity="center_horizontal"
    android:padding="10dp">

    <!-- 🧾 Page Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Requests"
        android:textColor="#FF6F00"
        android:textStyle="bold"
        android:textSize="36sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center" />

    <!-- 🔍 Filter Bar -->
    <LinearLayout
        android:id="@+id/filterContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="@drawable/card_bg_white"
        android:elevation="4dp"
        android:layout_marginBottom="10dp"
        android:layout_marginHorizontal="8dp"
        android:clipToOutline="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter by Date:"
            android:textColor="#000"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textStyle="bold"
            android:textColor="#FF6F00"
            android:textSize="14sp"
            android:padding="6dp"
            android:background="@drawable/date_selector_bg"
            android:layout_marginEnd="10dp" />

        <ImageView
            android:id="@+id/btnCalendar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/outline_calendar_month_24"
            android:contentDescription="Pick Date"
            android:tint="#FF6F00"
            tools:ignore="UseAppTint" />

        <Space
            android:layout_width="20dp"
            android:layout_height="wrap_content" />

        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/outline_autorenew_24"
            android:contentDescription="Refresh"
            android:tint="#FF6F00"
            tools:ignore="UseAppTint" />
    </LinearLayout>

    <!-- 🔄 Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:indeterminate="true"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        android:indeterminateTint="#FF9800" />

    <!-- 📋 Bookings List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerBookings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:padding="4dp"
        android:clipToPadding="false" />

    <!-- 💳 Transaction Summary -->
    <LinearLayout
        android:id="@+id/transactionSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_white"
        android:elevation="5dp"
        android:padding="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:layout_marginHorizontal="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💳 Transactions Summary"
            android:textColor="#FF6F00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvTotalTasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Tasks: 12"
            android:textColor="#000"
            android:textSize="14sp"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/tvCompletedTasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completed: 4"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/tvPendingTasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending: 8"
            android:textColor="#F44336"
            android:textSize="14sp"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/tvTotalEarnings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Earnings: ₹1355"
            android:textColor="#000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="5dp" />
    </LinearLayout>

    <!-- ⚙️ Bottom Menu -->
    <include
        android:id="@+id/bottomMenu"
        layout="@layout/bottom_menu_layout"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="5dp"
        android:padding="8dp" />

</LinearLayout>
