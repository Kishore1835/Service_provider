<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient_orange">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- 🧾 Animated Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assign New Task"
            android:textColor="#FF6F00"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="25dp"
            android:gravity="center"
            android:animateLayoutChanges="true"
            android:alpha="1" />


        <!-- 🏷️ Task Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FFF"
            app:startIconDrawable="@drawable/baseline_add_task_24"
            app:startIconTint="#FF9800"
            app:hintTextColor="@color/black"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTaskName"
                android:hint="Task Name"
                android:textColor="#000"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 📝 Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FFF"
            app:startIconDrawable="@drawable/outline_assignment_24"
            app:startIconTint="#FF9800"
            android:layout_marginTop="16dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:hint="Task Description"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:maxLines="5"
                android:textColor="#000"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 📍 From Location -->
        <LinearLayout
            android:id="@+id/fromLocationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutFromLocation"
                android:layout_width="0dp"
                android:layout_weight="1.7"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="#FFFFFF"
                app:startIconDrawable="@drawable/outline_add_location_alt_24"
                app:startIconTint="#FF9800">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFromLocation"
                    android:hint="Fetching current location..."
                    android:inputType="text"
                    android:textColor="#000"
                    android:textSize="16sp"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnChooseFrom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9800"
                android:textColor="#FFF"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp" />
        </LinearLayout>

        <!-- 📍 To Location (Search field) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutToLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FFFFFF"
            app:startIconDrawable="@drawable/outline_add_location_alt_24"
            app:startIconTint="#FF9800">

            <AutoCompleteTextView
                android:id="@+id/etToLocation"
                android:hint="Enter destination..."
                android:inputType="text"
                android:textColor="#000"
                android:textSize="16sp"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 💰 Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="filled"
            app:boxBackgroundColor="#FFFFFF"
            app:startIconDrawable="@drawable/outline_account_balance_wallet_24"
            app:startIconTint="#FF9800">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAmount"
                android:hint="Amount (₹)"
                android:inputType="numberDecimal"
                android:textColor="#000"
                android:textSize="16sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 📷 Upload Photo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnUploadPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Photo"
                android:backgroundTint="#FF9800"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:elevation="4dp" />

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="10dp"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:background="@drawable/outline_account_circle_24"
                android:elevation="3dp" />
        </LinearLayout>

        <!-- ✅ Submit -->
        <Button
            android:id="@+id/btnSubmitTask"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:text="Submit Task"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:elevation="6dp" />

        <!-- 🌍 Bottom Menu -->
        <include
            android:id="@+id/bottomMenu"
            layout="@layout/bottom_menu_layout"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="100dp"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
