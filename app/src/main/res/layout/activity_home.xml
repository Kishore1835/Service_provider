<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".HomeActivity">

    <!-- 🔸 Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FF9800"
        android:paddingHorizontal="15dp">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SnapJob"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <LinearLayout
            android:id="@+id/timeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:gravity="end">

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- --, ----"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- 🧍 User Info -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        android:layout_margin="15dp"
        android:backgroundTint="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="15dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:src="@drawable/user"
                android:background="@drawable/circle_background"
                android:padding="3dp"
                android:layout_marginEnd="15dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="user@email.com"
                    android:textColor="@color/black"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_verified"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/tvVerifiedStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verified User"
                        android:textColor="#2E7D32"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 🚪 Logout Button -->
                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Logout"
                    android:textColor="@color/white"
                    android:backgroundTint="#D32F2F"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="15dp"
                    android:elevation="3dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 🔍 Search Services -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="15dp"
        android:paddingTop="10dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etSearchService"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="45dp"
            android:hint="Search nearby services..."
            android:background="@drawable/edittext_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="@color/black"
            android:textSize="15sp" />

        <Spinner
            android:id="@+id/spinnerDistance"
            android:layout_width="100dp"
            android:layout_height="45dp"
            android:layout_marginStart="10dp"
            android:entries="@array/distance_array"
            android:background="@drawable/spinner_bg" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSearch"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Search Nearby Jobs"
        android:backgroundTint="#FF9800"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:elevation="5dp"
        android:layout_margin="15dp" />

    <!-- 📋 Task List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTasks"
        android:layout_below="@id/btnSearch"
        android:layout_above="@id/bottomMenu"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:paddingBottom="100dp" />

    <!-- ➕ Floating Add Task Button -->
    <!-- ⚙️ Bottom Menu -->
    <!-- ⚙️ Bottom Menu -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_marginLeft="320dp"
        android:layout_marginBottom="32dp"
        android:contentDescription="Add Task"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FF9800"
        app:elevation="6dp"
        app:tint="@color/white" />

    <include layout="@layout/bottom_menu_layout" android:id="@+id/bottomMenu" />

</LinearLayout>
